generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PlatformRole {
  ORG_LEADER
  MEMBER
}

enum OrgRole {
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum Recurrence {
  ONE_OFF
  DAILY
  WEEKLY
  MONTHLY
}

enum ReminderType {
  NONE
  ALL_DAILY_SUMMARY
  ASSIGNEE_DAILY_SUMMARY
  ASSIGNEE_OWN_SHIFT
  ASSIGNEE_PRE_SHIFT
}

enum NotificationType {
  REMINDER_SENT
  MEMBER_JOINED
  INVITED_TO_ORG
}

enum NameMode {
  ACCOUNT_NAME
  DISPLAY_NAME
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  kindeId              String    @unique
  email                String    @unique
  name                 String?
  platformRole         PlatformRole @default(MEMBER)
  plan                 Plan         @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  ownedOrgs       Organization[]
  memberships     OrgMember[]
  invitationsSent Invitation[]
  createdShifts   Shift[]
  notifications   Notification[]
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reminderType        ReminderType @default(NONE)
  reminderHourUtc     Int          @default(7)
  reminderLeadMinutes Int          @default(60)
  nameMode            NameMode     @default(ACCOUNT_NAME)

  owner       User         @relation(fields: [ownerId], references: [id])
  members     OrgMember[]
  shifts      Shift[]
  invitations Invitation[]
}

model OrgMember {
  id          String   @id @default(cuid())
  userId      String
  orgId       String
  role        OrgRole  @default(MEMBER)
  displayName String?
  showEmail   Boolean  @default(true)
  joinedAt    DateTime @default(now())

  user            User             @relation(fields: [userId], references: [id])
  org             Organization     @relation(fields: [orgId], references: [id])
  shiftAssignments ShiftAssignee[]
  completions     ShiftCompletion[]

  @@unique([userId, orgId])
}

model Shift {
  id          String     @id @default(cuid())
  orgId       String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  recurrence  Recurrence @default(ONE_OFF)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  org         Organization      @relation(fields: [orgId], references: [id])
  createdBy   User              @relation(fields: [createdById], references: [id])
  assignees   ShiftAssignee[]
  completions ShiftCompletion[]
}

model ShiftAssignee {
  id       String @id @default(cuid())
  shiftId  String
  memberId String

  shift  Shift     @relation(fields: [shiftId], references: [id])
  member OrgMember @relation(fields: [memberId], references: [id])

  @@unique([shiftId, memberId])
}

model ShiftCompletion {
  id            String    @id @default(cuid())
  shiftId       String
  completedById String
  completedAt   DateTime  @default(now())
  notes         String?

  shift       Shift     @relation(fields: [shiftId], references: [id])
  completedBy OrgMember @relation(fields: [completedById], references: [id])
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  orgId       String
  invitedById String
  token       String    @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  org       Organization @relation(fields: [orgId], references: [id])
  invitedBy User         @relation(fields: [invitedById], references: [id])
}
